From 465e84e4f84e486802447b431c357283d0776bad Mon Sep 17 00:00:00 2001
From: Matthieu Bouron <matthieu.bouron@gmail.com>
Date: Mon, 15 Jun 2026 11:16:47 +0200
Subject: [PATCH 2/2] Add BIO_read_ex

Backport the OpenSSL size_t-clean read accessor. It is the read
counterpart to the existing BIO_write_ex and wraps BIO_read, whose error
returns were already canonicalized in preparation for this. On success
it returns one and sets *out_read to the number of bytes read; it
returns zero on EOF or error.

As with BIO_write_ex, out_read may be NULL and is zeroed up front, so
callers never observe a stale count on failure (unlike OpenSSL). Reads
are clamped to INT_MAX since there is no size_t-clean bread callback;
a larger request simply yields a short read, which the API permits.
---
 crypto/bio/bio.cc      | 18 ++++++++++++++++++
 crypto/bio/bio_test.cc | 40 ++++++++++++++++++++++++++++++++++++++++
 include/openssl/bio.h  |  7 +++++++
 3 files changed, 65 insertions(+)

diff --git a/crypto/bio/bio.cc b/crypto/bio/bio.cc
index 9250be0fb..d92fe15bd 100644
--- a/crypto/bio/bio.cc
+++ b/crypto/bio/bio.cc
@@ -96,6 +96,24 @@ int BIO_read(BIO *bio, void *buf, int len) {
   return ret;
 }
 
+int BIO_read_ex(BIO *bio, void *data, size_t len, size_t *out_read) {
+  if (out_read != nullptr) {
+    *out_read = 0;
+  }
+  // There is no `size_t`-clean `bread` callback yet, so clamp to the range of
+  // the int-based |BIO_read|. A short read is permitted, so the caller learns
+  // the actual count via `*out_read`.
+  int ret = BIO_read(bio, data, static_cast<int>(std::min(len, size_t{INT_MAX})));
+  if (ret <= 0) {
+    // Zero (EOF) and negative (error) both report failure for |BIO_read_ex|.
+    return 0;
+  }
+  if (out_read != nullptr) {
+    *out_read = static_cast<size_t>(ret);
+  }
+  return 1;
+}
+
