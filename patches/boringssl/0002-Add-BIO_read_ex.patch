   auto *impl = FromOpaque(bio);
   if (impl == nullptr || impl->method->bgets == nullptr) {
diff --git a/crypto/bio/bio_test.cc b/crypto/bio/bio_test.cc
index 861eb2cfb..7a6654472 100644
--- a/crypto/bio/bio_test.cc
+++ b/crypto/bio/bio_test.cc
@@ -1200,5 +1200,45 @@ TEST(BIOTest, BIOChain) {
                    {method2->first, method3->first, method4->first});
 }
 
+TEST(BIOTest, ReadEx) {
+  static const char kData[] = "abcdefghijklmno";  // 15 bytes
+  UniquePtr<BIO> bio(BIO_new_mem_buf(kData, strlen(kData)));
+  ASSERT_TRUE(bio);
+
+  char buf[6];
+  size_t read = 42;
+
+  // A successful read reports the number of bytes read in |*out_read|.
+  ASSERT_EQ(BIO_read_ex(bio.get(), buf, sizeof(buf), &read), 1);
+  EXPECT_EQ(read, 6u);
+  EXPECT_EQ(Bytes(buf, read), Bytes("abcdef"));
+
+  // |out_read| may be NULL.
+  ASSERT_EQ(BIO_read_ex(bio.get(), buf, sizeof(buf), nullptr), 1);
+  EXPECT_EQ(Bytes(buf, 6), Bytes("ghijkl"));
+
+  // A short read (more requested than available) returns only what is there.
+  read = 42;
+  ASSERT_EQ(BIO_read_ex(bio.get(), buf, sizeof(buf), &read), 1);
+  EXPECT_EQ(read, 3u);
+  EXPECT_EQ(Bytes(buf, read), Bytes("mno"));
+
+  // Once consumed, the read-only buffer returns EOF, which |BIO_read_ex| reports
+  // as failure with |*out_read| set to zero.
+  read = 42;
+  EXPECT_EQ(BIO_read_ex(bio.get(), buf, sizeof(buf), &read), 0);
+  EXPECT_EQ(read, 0u);
+
+  // Reading from a |BIO_METHOD| with no read implementation fails.
+  UniquePtr<BIO_METHOD> method(BIO_meth_new(0, nullptr));
+  ASSERT_TRUE(method);
+  UniquePtr<BIO> method_bio(BIO_new(method.get()));
+  ASSERT_TRUE(method_bio);
+  BIO_set_init(method_bio.get(), 1);
+  read = 42;
+  EXPECT_EQ(BIO_read_ex(method_bio.get(), buf, sizeof(buf), &read), 0);
+  EXPECT_EQ(read, 0u);
+}
+
 }  // namespace
 BSSL_NAMESPACE_END
diff --git a/include/openssl/bio.h b/include/openssl/bio.h
index 5c3dda0c3..d4b27d75f 100644
--- a/include/openssl/bio.h
+++ b/include/openssl/bio.h
@@ -72,6 +72,13 @@ OPENSSL_EXPORT int BIO_up_ref(BIO *bio);
 // bytes read, zero on EOF, or a negative number on error.
 OPENSSL_EXPORT int BIO_read(BIO *bio, void *data, int len);
 
+// BIO_read_ex attempts to read |len| bytes into |data|. On success, it returns
+// one and sets |*out_read| to the number of bytes read. It returns zero on EOF
+// or error. |out_read| may be NULL to ignore the value. At most |INT_MAX| bytes
+// will be read in a single call.
+OPENSSL_EXPORT int BIO_read_ex(BIO *bio, void *data, size_t len,
+                               size_t *out_read);
