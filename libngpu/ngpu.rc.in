#include <winver.h>

VS_VERSION_INFO VERSIONINFO
  FILEVERSION @NGPU_MAJOR_VERSION@,@NGPU_MINOR_VERSION@,@NGPU_MICRO_VERSION@,0
  PRODUCTVERSION @NGPU_MAJOR_VERSION@,@NGPU_MINOR_VERSION@,@NGPU_MICRO_VERSION@,0
  FILEFLAGSMASK 0
  FILEFLAGS 0
  FILEOS VOS__WINDOWS32
  FILETYPE VFT_DLL
  FILESUBTYPE VFT2_UNKNOWN
  BEGIN
    BLOCK "StringFileInfo"
    BEGIN
      BLOCK "040904B0"
      BEGIN
        VALUE "CompanyName", "Nope Forge"
        VALUE "FileDescription", "nope.gl"
        VALUE "FileVersion", "@NGPU_VERSION@"
        VALUE "InternalName", "ngpu-@NGPU_MAJOR_VERSION@.dll"
        VALUE "LegalCopyright", "@NGPU_COPYRIGHT@"
        VALUE "OriginalFilename", "ngpu-@NGPU_MAJOR_VERSION@.dll"
        VALUE "ProductName", "ngpu"
        VALUE "ProductVersion", "@NGPU_VERSION@"
        VALUE "Licence", "Apache-2.0 license"
        VALUE "Info", "https://github.com/NopeForge/nope.gl"
      END
    END
    BLOCK "VarFileInfo"
    BEGIN
      VALUE "Translation", 0x409, 1200
    END
  END
